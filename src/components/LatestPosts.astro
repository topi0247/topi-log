---
import type { UnifiedPost } from '@/lib/blog';
import PostCard from '@/components/PostCard.astro';

interface Props {
	posts: UnifiedPost[];
	showHeading?: boolean;
}

const { posts, showHeading = true } = Astro.props;
---

<div class="mt-6">
	{showHeading && <h2 class="text-xs font-medium text-gray-400 tracking-widest mb-2">最新の記事</h2>}
	<div class="flex flex-col gap-3">
		{posts.map((post) => (
			<PostCard post={post} />
		))}
	</div>
</div>
