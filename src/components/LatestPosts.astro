---
import type { UnifiedPost } from '@/lib/blog';
import PostCard from '@/components/PostCard.astro';

interface Props {
	posts: UnifiedPost[];
	showHeading?: boolean;
}

const { posts, showHeading = true } = Astro.props;
---

<div class="mt-6">
	{showHeading && <h2 class="text-xs font-medium text-gray-400 tracking-widest mb-2">最新の記事</h2>}
	<div class="flex flex-col gap-3">
		{posts.map((post) => (
			<PostCard post={post} />
		))}
	</div>
	{showHeading && (
		<div class="text-center mt-4">
			<a href="/articles" class="text-sm text-sky-500 hover:text-sky-700 no-underline transition-colors">
				もっと見る →
			</a>
		</div>
	)}
</div>
